# Example Environment Variables Setup
# Rename this file to .env or create a new .env file and copy these contents in.

# Your local server port (Render will automatically override this)
PORT=5000

# Your MongoDB Atlas Connection String
# Replace <username>, <password>, and cluster info with your actual credentials
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.abcde.mongodb.net/lumina_spectacles?retryWrites=true&w=majority

# Your JSON Web Token Secret Key
# Change this to any long, random string of characters before deploying to production!
JWT_SECRET=supersecretjwtkey_please_change_in_production
